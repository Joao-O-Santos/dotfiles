# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5
}

# ADDED: display if vpn is connected
order += "path_exists VPN"
order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
# CHANGED: ignore battery on desktop (uncomment in laptops)
#order += "battery all"
order += "disk /"
order += "load"
order += "memory"
order += "tztime local"

# ADDED: report if I'm using a ppp VPN
path_exists VPN {
	path = "/proc/sys/net/ipv4/conf/ppp0"
}

# ADDED: only display if ipv6 is on or not (don't display ipv6 ip)
ipv6 {
	format_up = "ipv6: yes"
}

wireless _first_ {
        format_up = "W: (%quality at %essid) %ip"
        format_down = "W: down"
}

ethernet _first_ {
        format_up = "E: %ip (%speed)"
        format_down = "E: down"
}

battery all {
        format = "%status %percentage %remaining"
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

# CHANGED: only display used memory not available
memory {
        format = "%used" # | %available"
        threshold_degraded = "1G"
        format_degraded = "MEMORY < %available"
}

tztime local {
        format = "%Y-%m-%d %H:%M:%S"
}
