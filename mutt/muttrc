# General config file

# Editor and charachter set settings
set editor = $EDITOR
set send_charset = "utf-8"

# IMAP settings
unset imap_passive
set imap_keepalive=300
set mail_check=30
set imap_check_subscribed

# Mailboxes and caches settings
set mbox_type = Maildir
set tmpdir = $HOME
set header_cache = $XDG_CACHE_HOME
set message_cachedir = $XDG_CACHE_HOME

# Ui settings
color index white red "~N"
set date_format="%d-%b %H:%M"
set wrap=78
# No "+" signs when lines wrap
unset markers

# email display and thread view settings
set sort = threads
set sort_aux = last-date-received
bind index - collapse-thread
bind index _ collapse-all

# email handling settings
set beep_new=yes
set fast_reply=yes
set include=yes
set mime_forward=yes

# Vi keybindings
bind pager j next-line
bind pager k previous-line
bind attach,index,pager \CD next-page
bind attach,index,pager \CU previous-page
bind pager g top
bind pager G bottom
bind attach,index g first-entry
bind attach,index G last-entry
bind index r group-reply

# Source mail config
source ~/.config/mutt/imap
