{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./STYLE.md",
    "./AGENTS.md"
  ],
  "default_agent": "planner",
  "agent": {
    "planner": {
      "model": "huggingface/zai-org/GLM-5.1",
      "fallback": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
      "description": "Primary orchestrator and default agent",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": {
          "*": "allow"
        }
      }
    },
    "automation": {
      "model": "opencode/minimax-m2.5-free",
      "fallback": "openrouter/minimax/minimax-m2.5:free",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    },
    "writer": {
      "model": "opencode/nemotron-3-super-free",
      "fallback": "mistral/mistral-medium-latest",
      "description": "Unified manuscript drafting (empirical/theoretical)",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": "deny"
      }
    },
    "reviewer": {
      "model": "mistral/mistral-large-latest",
      "fallback": "openrouter/qwen/qwen3-coder:free",
      "description": "Critique and revision memos",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow"
      }
    },
    "guard": {
      "model": "huggingface/google/gemma-4-31B-it",
      "fallback": "openrouter/z-ai/glm-4.5-air:free",
      "description": "Safety checkpoints and regression control",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "webfetch": "deny"
      }
    },
    "literature-review": {
      "model": "opencode/big-pickle",
      "fallback": "huggingface/google/gemma-4-31B-it",
      "description": "Fast academic search and paper summaries",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow"
      }
    },
    "deep-research": {
      "model": "openrouter/google/gemma-4-31b-it:free",
      "fallback": "huggingface/google/gemma-4-31B-it",
      "description": "Exhaustive multi-step research",
      "mode": "subagent",
      "permission": {
        "webfetch": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },
    "r-analysis": {
      "model": "huggingface/zai-org/GLM-5.1",
      "description": "R/Quarto pipeline edits",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow"
      }
    }
  }
}
