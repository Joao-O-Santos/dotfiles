{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./STYLE.md",
    "./AGENTS.md"
  ],
  "default_agent": "planner",
  "model": "opencode/big-pickle",
  "small_model": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "planner": {
      "model": "opencode/big-pickle",
      "fallback": "openrouter/nvidia/nemotron-3-super-120b-a12b:free",
      "description": "Primary orchestrator and default agent",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "task": {
          "*": "allow"
        }
      }
    },
    "automation": {
      "model": "opencode/minimax-m2.5-free",
      "fallback": "openrouter/minimax/minimax-m2.5:free",
      "description": "Shell/git automation with direct bash access",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "webfetch": "allow",
        "task": {
          "*": "allow"
        }
      }
    },
    "writer": {
      "model": "opencode/nemotron-3-super-free",
      "fallback": "mistral/mistral-medium-latest",
      "description": "Unified manuscript drafting (empirical/theoretical)",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": "deny"
      }
    },
    "reviewer": {
      "model": "mistral/mistral-large-latest",
      "fallback": "openrouter/mistralai/mistral-large-latest",
      "description": "Critique and revision memos"
    },
    "guard": {
      "model": "opencode/minimax-m2.5-free",
      "fallback": "mistral/mistral-medium-latest",
      "description": "Safety checkpoints and regression control"
    },
    "literature-review": {
      "model": "openrouter/google/gemini-3.1-flash-lite-preview",
      "fallback": "openrouter/google/gemini-3.1-flash-preview",
      "description": "Fast academic search and paper summaries",
      "permission": {
        "webfetch": "allow"
      }
    },
    "deep-research": {
      "model": "openrouter/alibaba/tongyi-deepresearch-30b-a3b",
      "fallback": "openrouter/google/gemini-2.5-pro",
      "description": "Exhaustive multi-step research via Tongyi DeepResearch",
      "mode": "subagent",
      "permission": {
        "webfetch": "allow",
        "edit": "allow",
        "bash": "deny"
      }
    },
    "r-analysis": {
      "model": "mistral/devstral-2",
      "fallback": "openrouter/qwen/qwen3-coder",
      "description": "R/Quarto pipeline edits"
    }
  }
}
