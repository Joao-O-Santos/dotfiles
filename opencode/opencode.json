{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "./STYLE.md",
    "./AGENTS.md"
  ],
  "default_agent": "planner",
  "permission": {
    "bash": {
      "*": "deny",
      "ls *": "allow",
      "ll *": "allow",
      "la *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "more *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "tree *": "allow",
      "du *": "allow",
      "df *": "allow",
      "realpath *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "which *": "allow",
      "type *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "xargs *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git blame *": "allow",
      "git rev-parse *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git stash list *": "allow",
      "R *": "allow",
      "Rscript *": "allow",
      "quarto *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "date": "allow",
      "whoami": "allow",
      "uname *": "allow"
    },
    "external_directory": {
      "~/lit/**": "allow"
    }
  },
  "agent": {
    "planner": {
      "model": "opencode/big-pickle",
      "description": "Primary orchestrator and default agent",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "task": {
          "*": "allow"
        }
      }
    },
    "automation": {
      "model": "opencode/minimax-m2.5-free",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "sudo *": "deny",
          "sudo": "deny",
          "rm -rf /": "deny",
          "rm -rf ~": "deny",
          "rm -r /": "deny",
          "rm -r ~": "deny",
          "dd *": "deny",
          "mkfs *": "deny",
          "fdisk *": "deny",
          "format *": "deny",
          "chmod 777 *": "deny",
          "rm *": "ask",
          "git push *": "ask",
          "git reset --hard *": "ask",
          "git clean *": "ask",
          "yay -S *": "ask",
          "yay -S": "ask",
          "pacman -S *": "ask"
        }
      }
    },
  "writer": {
    "model": "mistral/mistral-medium-latest",
    "description": "Unified manuscript drafting (empirical/theoretical)",
    "mode": "primary",
    "permission": {
      "edit": "allow",
      "webfetch": "allow"
    }
  },
  "reviewer": {
    "model": "mistral/mistral-large-latest",
    "fallback": "opencode-go/glm-5.1",
    "description": "Critique and revision memos",
    "mode": "primary",
    "permission": {
      "edit": "deny",
      "webfetch": "allow"
    }
  },
    "guard": {
      "model": "opencode/minimax-m2.5",
      "fallback": "openrouter/z-ai/glm-4.5-air:free",
      "description": "Safety checkpoints and regression control",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "webfetch": "deny"
      }
    },
    "literature-review": {
      "model": "opencode/minimax-m2.5",
      "fallback": "openrouter/z-ai/glm-4.5-air:free",
      "description": "Fast academic search and paper summaries",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "ll *": "allow",
          "la *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "less *": "allow",
          "more *": "allow",
          "wc *": "allow",
          "stat *": "allow",
          "file *": "allow",
          "tree *": "allow",
          "du *": "allow",
          "df *": "allow",
          "realpath *": "allow",
          "basename *": "allow",
          "dirname *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "which *": "allow",
          "type *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "tr *": "allow",
          "xargs *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git show *": "allow",
          "git blame *": "allow",
          "git rev-parse *": "allow",
          "git branch *": "allow",
          "git remote *": "allow",
          "git tag *": "allow",
          "git stash list *": "allow",
          "R *": "allow",
          "Rscript *": "allow",
          "quarto *": "allow",
          "pdftotext *": "allow",
          "pdftotext": "allow",
          "pwd": "allow",
          "echo *": "allow",
          "date": "allow",
          "whoami": "allow",
          "uname *": "allow"
        }
      }
    },
    "deep-research": {
      "model": "opencode-go/kimi-k2.5",
      "fallback": "opencode/big-pickle",
      "description": "Exhaustive multi-step research",
      "mode": "primary",
      "permission": {
        "webfetch": "allow",
        "edit": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "ll *": "allow",
          "la *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "less *": "allow",
          "more *": "allow",
          "wc *": "allow",
          "stat *": "allow",
          "file *": "allow",
          "tree *": "allow",
          "du *": "allow",
          "df *": "allow",
          "realpath *": "allow",
          "basename *": "allow",
          "dirname *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "which *": "allow",
          "type *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "tr *": "allow",
          "xargs *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git show *": "allow",
          "git blame *": "allow",
          "git rev-parse *": "allow",
          "git branch *": "allow",
          "git remote *": "allow",
          "git tag *": "allow",
          "git stash list *": "allow",
          "R *": "allow",
          "Rscript *": "allow",
          "quarto *": "allow",
          "pdftotext *": "allow",
          "pdftotext": "allow",
          "pwd": "allow",
          "echo *": "allow",
          "date": "allow",
          "whoami": "allow",
          "uname *": "allow"
        }
      }
    },
    "r-analysis": {
      "model": "opencode-go/minimax-m2.7",
      "fallback": "openrouter/qwen/qwen3-coder:free",
      "description": "R/Quarto pipeline edits",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "sudo *": "deny",
          "sudo": "deny",
          "rm -rf /": "deny",
          "rm -rf ~": "deny",
          "rm -r /": "deny",
          "rm -r ~": "deny",
          "dd *": "deny",
          "mkfs *": "deny",
          "fdisk *": "deny",
          "format *": "deny",
          "chmod 777 *": "deny",
          "rm *": "ask",
          "git push *": "ask",
          "git reset --hard *": "ask",
          "git clean *": "ask",
          "yay -S *": "ask",
          "yay -S": "ask",
          "pacman -S *": "ask"
        }
      }
    }
  }
}
