{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "${HOME}/.config/opencode/STYLE.md",
    "${HOME}/.config/opencode/AGENTS.md"
  ],
  "default_agent": "planner",
  "enabled_providers": [
    "opencode-go", "opencode", "ollama-cloud",
    "mistral", "openrouter"
  ],
  "permission": {
    "bash": {
      "*": "deny",
      "git status": "allow", "git log *": "allow",
      "git diff *": "allow", "git show *": "allow",
      "ls *": "allow", "wc *": "allow",
      "grep *": "allow", "rg *": "allow", "find *": "allow",
      "tso *": "allow", "chkdrft *": "allow", "toc *": "allow",
      "pdftotext *": "allow"
    },
    "external_directory": {
      "${HOME}/.config/opencode/**": "allow",
      "${HOME}/.config/opencode/auth.json": "deny",
      "${HOME}/.config/opencode/mcp_keys.sh": "deny",
      "/tmp/**": "allow"
    },
    "read": {
      "${HOME}/.config/opencode/**": "allow",
      "${HOME}/.config/opencode/auth.json": "deny",
      "${HOME}/.config/opencode/mcp_keys.sh": "deny",
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "local", "enabled": true,
      "command": [
        "npx", "-y", "@upstash/context7-mcp",
        "--api-key", "{env:CONTEXT7_API_KEY}"
      ]
    },
    "citecheck": {
      "type": "local", "enabled": true,
      "command": ["npx", "-y", "@jhlee0619/citecheck@latest"],
      "environment": { "CROSSREF_MAILTO": "{env:CROSSREF_MAILTO}" }
    },
    "openalex": {
      "type": "local", "enabled": true,
      "command": ["npx", "-y", "@cyanheads/openalex-mcp-server@latest"],
      "environment": {
        "OPENALEX_API_KEY": "{env:OPENALEX_API_KEY}",
        "OPENALEX_EMAIL": "{env:OPENALEX_EMAIL}"
      }
    },
    "semantic-scholar": {
      "type": "local", "enabled": true,
      "command": ["npx", "-y", "paperplain-mcp@latest"]
    }
  },
  "agent": {
    "planner": {
      "description": "Primary orchestrator and default agent",
      "mode": "primary",
      "model": "{env:PLANNER_MODEL}", "temperature": 0.1,
      "steps": 20,
      "permission": { "edit": "deny", "webfetch": "allow", "task": { "*": "allow" } }
    },
    "automation": {
      "description": "Shell, git, and terminal-native execution",
      "mode": "primary",
      "model": "{env:AUTOMATION_MODEL}", "temperature": 0.3,
      "steps": 30,
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "ask", "git merge *": "ask",
          "git reset --hard *": "ask", "git clean *": "ask",
          "rm *": "ask", "chmod 777 *": "ask",
          "git push *": "deny",
          "sudo *": "deny", "yay -S *": "deny", "pacman -S *": "deny",
          "rm -rf /": "deny", "rm -rf ~": "deny",
          "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny"
        }
      }
    },
    "writer": {
      "description": "Unified manuscript drafting (empirical/theoretical)",
      "mode": "primary",
      "model": "{env:WRITER_MODEL}", "temperature": 0.8,
      "steps": 10,
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "git status": "allow", "git log *": "allow",
          "git diff *": "allow", "git show *": "allow",
          "ls *": "allow", "wc *": "allow",
          "grep *": "allow", "rg *": "allow", "find *": "allow",
          "sed *": "allow",
          "tso *": "allow", "chkdrft *": "allow", "toc *": "allow"
        }
      }
    },
    "reviewer-structure": {
      "description": "Big-picture critique: structure, arguments, impact",
      "mode": "subagent",
      "model": "{env:REVIEWER_STRUCTURE_MODEL}",
      "permission": { "edit": "deny", "webfetch": "allow" },
      "steps": 10
    },
    "reviewer-detail": {
      "description": "Detail critique: citations, conceptual clarity, argument issues",
      "mode": "subagent",
      "model": "{env:REVIEWER_DETAIL_MODEL}", "temperature": 0.3,
      "steps": 10,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "copyeditor": {
      "description": "Prose review: titles, paragraphs, sentences, words, markdown compliance",
      "mode": "subagent",
      "model": "{env:COPYEDITOR_MODEL}", "temperature": 0.4,
      "steps": 10,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "editor": {
      "description": "Manuscript review collation agent: sorts reviewer output chronologically",
      "mode": "subagent",
      "model": "{env:EDITOR_MODEL}", "temperature": 0.3,
      "steps": 8,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "guard": {
      "description": "Safety checkpoints and regression control",
      "mode": "subagent",
      "model": "{env:GUARD_MODEL}", "temperature": 0.2,
      "steps": 10,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "literature-reviewer": {
      "description": "Fast academic search and paper summaries",
      "mode": "subagent",
      "model": "{env:LITERATURE_REVIEWER_MODEL}",
      "temperature": 0.3,
      "steps": 12,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "deep-research": {
      "description": "Exhaustive multi-step research",
      "mode": "subagent",
      "model": "{env:DEEP_RESEARCH_MODEL}",
      "steps": 20,
      "permission": { "edit": "deny", "webfetch": "allow" }
    },
    "r-analysis": {
      "description": "R/Quarto pipeline edits",
      "mode": "primary",
      "model": "{env:R_ANALYSIS_MODEL}", "temperature": 0.2,
      "steps": 30,
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "ask", "git merge *": "ask", "git reset --hard *": "ask",
          "git clean *": "ask",
          "rm *": "ask",
          "git push *": "deny", "sudo *": "deny", "chmod 777 *": "deny",
          "yay -S *": "deny", "pacman -S *": "deny",
          "rm -rf /": "deny", "rm -rf ~": "deny",
          "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny"
        }
      }
    }
  },
  "plugin": [
    "opencode-snippets",
    "@cortexkit/opencode-magic-context",
    ["@plannotator/opencode@latest", {
      "workflow": "plan-agent",
      "planningAgents": ["plan", "planner"]
    }]
  ],
  "compaction": { "auto": false, "prune": false }
}
