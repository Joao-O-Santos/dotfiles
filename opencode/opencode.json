{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "${HOME}/.config/opencode/STYLE.md",
    "${HOME}/.config/opencode/AGENTS.md"
  ],
  "default_agent": "planner",
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "deny", "git merge *": "deny",
      "rm *": "ask", "git push *": "ask", "git reset --hard *": "ask", "git clean *": "ask", "yay -S *": "ask", "pacman -S *": "ask",
      "sudo *": "deny", "rm -rf /": "deny", "rm -rf ~": "deny", "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny", "chmod 777 *": "deny"
    },
    "external_directory": {
      "${HOME}/.config/opencode/**": "allow",
      "${HOME}/.config/opencode/auth.json": "deny",
      "~/lit/**": "allow"
    },
    "read": {
      "${HOME}/.config/opencode/auth.json": "deny"
    }
  },
  "agent": {
    "build": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Full-access development agent",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "task": { "*": "allow" },
        "bash": {
          "*": "allow",
          "git commit *": "ask",
          "git merge *": "ask",
          "rm *": "ask",
          "git push *": "ask",
          "git reset --hard *": "ask",
          "git clean *": "ask",
          "yay -S *": "ask",
          "pacman -S *": "ask",
          "sudo *": "deny",
          "rm -rf /": "deny",
          "rm -rf ~": "deny",
          "dd *": "deny",
          "mkfs *": "deny",
          "fdisk *": "deny",
          "chmod 777 *": "deny"
        }
      },
      "mcp": {
        "context7": {
          "type": "local",
          "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
          "enabled": true
        }
      }
    },
    "planner": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Primary orchestrator and default agent",
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "task": { "*": "allow" },
        "bash": {
          "*": "deny",
          "git status": "allow", "git log *": "allow", "git diff *": "allow", "git show *": "allow", "git commit *": "ask", "git merge *": "ask",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow", "ls *": "allow"
        }
      }
    },
    "automation": {
      "model": "opencode-go/qwen3.6-plus",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "ask", "git merge *": "ask",
          "rm *": "ask", "git push *": "ask", "git reset --hard *": "ask", "git clean *": "ask", "yay -S *": "ask", "pacman -S *": "ask",
          "sudo *": "deny", "rm -rf /": "deny", "rm -rf ~": "deny", "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny", "chmod 777 *": "deny"
        }
      }
    },
    "writer": {
      "model": "opencode-go/qwen3.6-plus",
      "description": "Unified manuscript drafting (empirical/theoretical)",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "deny", "git merge *": "deny",
          "rm *": "ask", "git push *": "ask", "git reset --hard *": "ask", "git clean *": "ask", "yay -S *": "ask", "pacman -S *": "ask",
          "sudo *": "deny", "rm -rf /": "deny", "rm -rf ~": "deny", "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny", "chmod 777 *": "deny"
        }
      }
    },
    "reviewer-structure": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Big-picture critique: structure, arguments, impact",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow"
        }
      }
    },
    "reviewer-detail": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Detail critique: citations, conceptual clarity, argument issues",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow"
        }
      },
      "mcp": {
        "citecheck": {
          "type": "local",
          "command": ["npx", "-y", "@jhlee0619/citecheck@latest"],
          "enabled": true
        }
      }
    },
    "copyeditor": {
      "model": "opencode-go/qwen3.5-plus",
      "description": "Prose review: titles, paragraphs, sentences, words, markdown compliance",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow"
        }
      },
      "mcp": {
        "citecheck": {
          "type": "local",
          "command": ["npx", "-y", "@jhlee0619/citecheck@latest"],
          "enabled": true
        }
      }
    },
    "editor": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Manuscript review collation agent: sorts reviewer output chronologically",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "deny", "git merge *": "deny",
          "rm *": "ask", "git push *": "ask", "git reset --hard *": "ask", "git clean *": "ask", "yay -S *": "ask", "pacman -S *": "ask",
          "sudo *": "deny", "rm -rf /": "deny", "rm -rf ~": "deny", "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny", "chmod 777 *": "deny"
        }
      }
    },
    "guard": {
      "model": "opencode-go/minimax-m2.5",
      "description": "Safety checkpoints and regression control",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "git log *": "allow", "git diff *": "allow", "git show *": "allow", "git status *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "tail *": "allow", "wc *": "allow"
        }
      }
    },
    "literature-reviewer": {
      "model": "opencode-go/qwen3.5-plus",
      "description": "Fast academic search and paper summaries",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow", "pdftotext *": "allow"
        }
      },
      "mcp": {
        "openalex": {
          "type": "local",
          "command": ["npx", "-y", "@cyanheads/openalex-mcp-server@latest"],
          "enabled": true
        },
        "semantic-scholar": {
          "type": "local",
          "command": ["npx", "-y", "paperplain-mcp@latest"],
          "enabled": true
        }
      }
    },
    "deep-research": {
      "model": "opencode-go/kimi-k2.6",
      "description": "Exhaustive multi-step research",
      "mode": "subagent",
      "permission": {
        "edit": "deny",
        "webfetch": "allow",
        "bash": {
          "*": "deny",
          "cat *": "allow", "head *": "allow", "tail *": "allow", "grep *": "allow", "rg *": "allow", "find *": "allow", "wc *": "allow", "pdftotext *": "allow"
        }
      },
      "mcp": {
        "openalex": {
          "type": "local",
          "command": ["npx", "-y", "@cyanheads/openalex-mcp-server@latest"],
          "enabled": true
        },
        "semantic-scholar": {
          "type": "local",
          "command": ["npx", "-y", "paperplain-mcp@latest"],
          "enabled": true
        }
      }
    },
    "r-analysis": {
      "model": "opencode-go/qwen3.6-plus",
      "description": "R/Quarto pipeline edits",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "webfetch": "allow",
        "bash": {
          "*": "allow",
          "git commit *": "ask", "git merge *": "ask",
          "rm *": "ask", "git push *": "ask", "git reset --hard *": "ask", "git clean *": "ask", "yay -S *": "ask", "pacman -S *": "ask",
          "sudo *": "deny", "rm -rf /": "deny", "rm -rf ~": "deny", "dd *": "deny", "mkfs *": "deny", "fdisk *": "deny", "chmod 777 *": "deny"
        }
      },
      "mcp": {
        "context7": {
          "type": "local",
          "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
          "enabled": true
        }
      }
    }
  },
  "plugin": [
    "opencode-snippets"
  ]
}
