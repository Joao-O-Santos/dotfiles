[general]
targets = gitlab, github

[gitlab]
service = gitlab
gitlab.login = YOUR_USER_NAME
gitlab.token = YOUR_TOKEN
gitlab.host = gitlab.com
gitlab.owned = True
gitlab.membership = True
gitlab.import_labels_as_tags = True

[github]
service = github
github.login = YOUR_USER_NAME
github.token = YOUR_TOKEN
github.username = YOUR_USER_NAME
